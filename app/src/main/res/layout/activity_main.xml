<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        tools:layout_editor_absoluteX="51dp"
        tools:layout_editor_absoluteY="152dp">

        <Button
            android:id="@+id/button"
            android:layout_width="match_parent"
            android:layout_height="82dp"
            android:onClick="abrirEntradasDigitaisCLP"
            android:text="ENTRADAS DIGITAIS DO CLP" />

        <Button
            android:id="@+id/button3"
            android:layout_width="match_parent"
            android:layout_height="84dp"
            android:onClick="abrirSaidasDigitaisCLP"
            android:text="SAÍDAS DIGITAIS DO CLP" />

        <Button
            android:id="@+id/button2"
            android:layout_width="match_parent"
            android:layout_height="77dp"
            android:onClick="abrirEntradasAnalogicasCLP"
            android:text="ENTRADAS ANALÓGICAS DO CLP" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>